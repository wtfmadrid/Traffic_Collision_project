b details",SourceToDestination:"Source \u2192 Destination",EditUpdateMethod:"Edit update method",EditWriteMethod:"Edit write method",CopyJob_UpdateMethodChangeWarningMessage:"Changing the update method may affect the current column mapping. You may need to reset or adjust the column mapping to ensure proper functionality.",CopyJob_FileFormatChangeWarningMessage:"Changing the file format and settings may impact the current column mapping. To ensure proper functionality, you may need to edit column mapping and re-import schemas.",CopyJob_ReseedTitle:"Changing these settings will reset the copy job. Are you sure you want to proceed?",CopyJob_ReseedContent:"This means the next copy run will restart from the initial full load instead of continuing from the last update. This action cannot be undone.",CopyJobUseNativeChangeDataCapture:"Use native change data capture",CopyJobCDCEnabledTable:"This table is CDC enabled",CopyJob_AutoGenerateColumnMapping:"Column mappings will be generated based on the selected columns",CopyJob_UpsertDisabledMessage:"Merge is not supported in full copy",CopyJob_OverwriteDisabledMessage:"Overwrite is not supported in incremental copy",CopyJob_AllTablesHaveCDCEnabled:"All {0} have CDC enabled.",CopyJob_AllTablesHaveCDCEnabledDescription:"Copy job uses CDC to automatically detect inserted, updated, and deleted rows.",CopyJob_IncrementalColumn_Info:"Your row insert/update will be captured. Deletion will not be captured.",CopyJob_IncrementalColumn_DateOnlyInfo:"Because date values don\u2019t include a time component, Copy job automatically applies delayed extraction from the last day to ensure there\u2019s no data loss or overlap between runs, safely managing incremental windows.",CopyJob_IncrementalColumn2_Info:"If a Date column is selected in Incremental column 1, you can specify another incremental column.",CopyJob_IncrementalColumnWithIndex:"Incremental column {0}",CopyJob_NativeCDC_Info:"Your row insert/update/delete will be captured.",CopyJob_NativeCDC_DisableColumnMapping:"Editing column mappings is not supported for native CDC enabled tables.",CopyJob_NoCDCTableMessage:"Your data store does not have log-based CDC enabled.",CopyJob_EnableNativeCDCMessage:"Enable them to automatically capture all inserts, updates, and deletions for seamless data changes in Copy Job.",CopyJob_CDCOnlyInsertAndUpdate:"Otherwise, only inserts and updates will be captured using the incremental column you provide.",CopyJob_MixCDCTableMessage:"Some selected tables do not have log-based CDC enabled.",CopyJob_UseIncrementalColumn:"Otherwise, all selected tables require incremental column to capture insert and update if you want to do incremental copy.",CopyJob_DetectingCDC:"Detecting change data capture capability...",CopyJob_AllTableCDCMessage:"Your selected tables have log-based CDC enabled.",CopyJob_AllTableCDCDescription:"Enjoy your journey to automatically capture all inserts, updates, and deletions to streamline data changes effortlessly in Copy Job.",CopyJob_AllSelectedTableNotCDC:"Your selected tables do not have log-based CDC enabled.",CopyJob_GetRunFailed:"Get copy job run failed.",KeyColumnsForMerge:"{0} for merge",InvokeCopyJobActivityConnectionToolTip:"Reference to the Copy job connection for authentication purpose.",InvokeDataBuildToolJobActivityConnectionToolTip:"Reference to the dbt job connection for authentication purpose.",InvokeDataBuildToolJobActivityOperationTypeToolTip:"The dbt command to use (build, compile, run, test, seed, snapshot)",InvokeDataBuildToolJobActivitySelectToolTip:'Specify selection criteria (for example, models, project, directory, package, tag, or path) to choose a subset of nodes to execute dbt. Learn more <a target="_blank" href="https://docs.getdbt.com/reference/node-selection/syntax#specifying-resources">here</a>',InvokeDataBuildToolJobActivityExcludeToolTip:'Specify exclusion criteria (for example, models, project, directory, package, tag, or path) to exclude a subset of nodes from dbt execution. Learn more <a target="_blank" href="https://docs.getdbt.com/reference/node-selection/exclude">here</a>',InvokeDataBuildToolJobActivityFullRefreshToolTip:'Specify if you wish to force dbt to rebuild all models from scratch. <a target="_blank" href="https://docs.getdbt.com/reference/commands/run#refresh-incremental-models">Learn more</a>',InvokeDataBuildToolJobActivityFailFastToolTip:'Specify if dbt should exit immediately if a single resource fails to build. <a target="_blank" href="https://docs.getdbt.com/reference/global-configs/failing-fast">Learn more</a>',InvokeDataBuildToolJobActivitySelectorNameToolTip:'Specify name of a selector from the project\'s selectors.yml. Using a selector will override select/exclude arguments. Learn more <a target="_blank" href="https://docs.getdbt.com/reference/node-selection/yaml-selectors">here</a>',CopyJob_AppendDataDescription:"On copy job run, new data will be added to the end of each table.",CopyJob_OverwriteDataDescription:"On copy job run, overwrite the existing data and schema using the new values.",CopyJob_MergeDataDescription:"On copy job run, update existing rows and insert new rows.",CopyJob_SinkNotSupportNativeCDC:"CDC is not supported for {0} as destinations. Please use watermark-based incremental copy, which requires specifying an incremental column to identify changes from the source.",CopyJob_UpdateMethodNotSupportNativeCDC:"CDC is only supported for destinations where the update method is merge. For all other update methods, please use watermark-based incremental copy, which requires specifying an incremental column to identify changes from the source.",CopyJob_NetChangesNativeCDC:"CDC is only supported for tables that allow net change tracking. For all other tables, please use watermark-based incremental copy, which requires specifying an incremental column to identify changes from the source.",CopyJob_ResetEntireCopyJob:"Reset entire copy job",CopyJob_SelectTablesToReset:"Select tables to reset",CopyJob_ResetDescription:"This will reset the incremental copy so that the next copy run will start from scratch.",CopyJob_ResetConfirmTitle:"Are you sure you want to reset?",CopyJob_ResetConfirmDescription:"This will reset the incremental copy so that the next copy run will start from scratch. This action cannot be undone.",CopyJob_CDFSourceWarning:"Based on your selected source, destination, and update method, the copy job will automatically detect inserted, updated, and deleted rows, and merge them to the destination. Please ensure that CDF is enabled for all source tables; otherwise, the copy will fail at runtime.",SelectVariable:"Select variable",ManageTarget:"Manage {0}",ChooseCopyJobMode:"Choose copy job mode",CopyJobOverwriteDestinationOnFullLoad:"Overwrite destination on full load",CopyJobOverwriteDestinationOnFullLoadDescription:"When overwrite destination on full load is enabled, the full load will delete all existing data at the destination before copying new data. Otherwise, the full copy will append data to the destination. If existing data is preserved at the destination, duplicate rows may appear.",CopyJob_CopyUsingFabricChangeDataFeed:"Using Change Data Feed",CopyJob_CopyUsingWatermarkColumn:"Using watermark column",CopyJob_IncrementalCopyDisabledTooltip:'Incremental copy is not supported for the selected {0}. Submit a request through <a target="_blank" href="https://community.fabric.microsoft.com/t5/Fabric-Ideas/idb-p/fbc_ideas/label-name/data%20factory%20%7c%20copy%20job">Fabric Ideas - Microsoft Fabric Community</a> if you would like this feature to be enabled.',CopyJob_FullCopyDisabledTooltip:'Full copy is not supported for the selected {0}. Using Incremental copy will perform an initial full copy on the first run and incremental copies in subsequent runs. Submit a request through <a target="_blank" href="https://community.fabric.microsoft.com/t5/Fabric-Ideas/idb-p/fbc_ideas/label-name/data%20factory%20%7c%20copy%20job">Fabric Ideas - Microsoft Fabric Community</a> if you want to enable full copy only for this data store.',CopyJob_MergeDisabledInFullCopyTooltip:'For a full copy, the "Overwrite" option functions like "Merge" but with better performance. Select "Overwrite" for merge-like behavior, or submit a request through <a target="_blank" href="https://community.fabric.microsoft.com/t5/Fabric-Ideas/idb-p/fbc_ideas/label-name/data%20factory%20%7c%20copy%20job">Fabric Ideas - Microsoft Fabric Community</a> if you specifically need "Merge" for full copy.',CopyJob_OverwriteDisabledInIncrementalCopyTooltip:'For incremental copy, the \u201cOverwrite\u201d option will replace all existing data in your destination with only the changed data, which can result in data loss. If you require this option, please submit a request through <a target="_blank" href="https://community.fabric.microsoft.com/t5/Fabric-Ideas/idb-p/fbc_ideas/label-name/data%20factory%20%7c%20copy%20job">Fabric Ideas - Microsoft Fabric Community</a>.',CopyJob_AppendDisabledInCDCCopyTooltip:'In CDC replication, the "Append" option is not supported yet. Submit a request through <a target="_blank" href="https://community.fabric.microsoft.com/t5/Fabric-Ideas/idb-p/fbc_ideas/label-name/data%20factory%20%7c%20copy%20job">Fabric Ideas - Microsoft Fabric Community</a> if you would like this feature to be enabled.',CopyJob_OverwriteDisabledInCDCCopyTooltip:'In CDC replication, the \u201cOverwrite\u201d option will replace all existing data in your destination with only the changed data, which can result in data loss. If you require this option, please submit a request through <a target="_blank" href="https://community.fabric.microsoft.com/t5/Fabric-Ideas/idb-p/fbc_ideas/label-name/data%20factory%20%7c%20copy%20job">Fabric Ideas - Microsoft Fabric Community</a>.',CopyJob_SCD2DisabledInBatchCopyTooltip:'The SCD Type 2 (SCD2) update method is not supported for batch copy. SCD2 preserves historical changes by inserting new records and expiring previous versions, which requires change tracking capabilities not available in batch copy. Use CDC replication to enable SCD2, or submit a request through <a target="_blank" href="https://community.fabric.microsoft.com/t5/Fabric-Ideas/idb-p/fbc_ideas/label-name/data%20factory%20%7c%20copy%20job">Fabric Ideas - Microsoft Fabric Community</a> if you would like SCD2 support in batch copy.',CopyJob_SCD2OnlySupportedInNativeCDCTooltip:'The SCD Type 2 (SCD2) update method is only supported in CDC replication. SCD2 relies on continuous change data capture to create new versions of records and maintain a complete history over time. Switch to CDC to use SCD2, or submit a request through <a target="_blank" href="https://community.fabric.microsoft.com/t5/Fabric-Ideas/idb-p/fbc_ideas/label-name/data%20factory%20%7c%20copy%20job">Fabric Ideas - Microsoft Fabric Community</a> if you require SCD2 outside CDC.',CopyJob_SCD2OnlySupportedInNativeCDCMessage:"The SCD Type 2 (SCD2) update method is only supported in CDC replication.",FullLoadBehavior:"Full load behavior",SourceStoreLabel:"Source store",DestinationStoreLabel:"Destination store",TryNewPipelineZoom:"Try the new pipeline zoom feature for better visibility on large pipelines!",EnablePipelineZoom:"Enable Pipeline Zoom",DisablePipelineZoom:"Disable Pipeline Zoom",AppendToDestination:"Append to destination",OverwriteDestination:"Overwrite destination",MergeToDestination:"Merge to destination",CopyJob_CopyFromSAPTable:"Copying data from SAP tables using the ABAP Add-On provides advanced features. To get started, deploy the ABAP Add-On on your SAP server.",CopyJob_UseSAPTableABAP:"Use ABAP Add-On",CopyJob_UseSAPTableClassic:"Use classic SAP Table connector",ABAPAddOn:"ABAP Add-On",CopyJob_SapTableAbapDateColumnAppendNotSupported:"The Append update method is not supported when using incremental copy with a date-type watermark column for SAP Table with ABAP Add-On. Please select a non-date watermark column or use a different update method.",CopyJob_DuplicateId:"Activity ID conflict detected",CopyJob_IncrementalCopyDuplicateIdMessage:"We found an issue in this copy job where multiple activities share the same ID. Updating the copy job will trigger a reset that regenerates the activity IDs.\n\nThis reset will clear the current run state. Your configuration will remain unchanged, but the job will be treated as a new configuration after the update.\n\nDo you want to continue and reset the copy job?",CopyJob_FullCopyDuplicateIdMessage:"We found an issue in this copy job where multiple activities share the same ID.\n\nUpdating the copy job will regenerate the activity IDs automatically.\n\nDo you want to continue?",Hourly:"Hourly",ByTheMinute:"By the minute",Repeat:"Repeat",StartDateAndTime:"Start date and time",EndDateAndTime:"End date and time",RunOptions:"Run options",RunOnce:"Run once",RunOnSchedule:"Run on schedule",Approve:"Approve",Approval:"Approval (Preview)",ApproverLabel:"Approver",ApproverLabelDescription:"Enter the approver email address. The approver will receive an email notification to approve or reject the request.",ApproverLabelPlaceholder:"Enter the approver email address.",ApprovalDescriptionLabelPlaceholder:"Enter the approval description.",ApprovalDescriptionLabelDescription:"Approval description is optional. It will be included in the email notification sent to the approver.",ApprovalActivityConnectionToolTip:"Select a connection",ApprovalActivityDetailsBanner:"Review the approval request below. The pipeline will continue once you approve or reject.",NoActivityWaitingForReview:"No activity is waiting for review.",RequestMessage:"Request message",ApproversLabel:"Approver(s)",RequestSubject:"Request subject",RunConditions:"Run conditions",RunConditions_NewRunCondition:"New run condition",RunConditions_SetUpDescription:"Set up a run condition to control when this pipeline runs.",RunConditions_EmptyStateTitle:"No run conditions yet",RunConditions_EmptyStateDescription:"Create conditions to control when your pipeline runs. Choose from schedule based, data availability, or custom triggers. Once added, you can view and manage them here.",RunConditions_SelectType:"Select a run condition type",RunConditions_ConditionName:"Name of the run condition",RunConditions_CustomDescription:"Run based on upstream pipelines and their condition values.",RunConditions_DataAvailability:"Data availability",RunConditions_DataAvailabilityDescription:"Run when data is available in sources.",RunConditions_TimeBased:"Time based",RunConditions_TimeBasedDescription:"Run based on upstream pipeline schedule.",RunConditions_EnterConditionName:"Enter condition name (Ex: chaining01)",RunConditions_RunDimensionName:"Name of the run dimension",RunConditions_RunDimensionNameDescription:"The run dimension name used to match upstream pipeline outputs.",RunConditions_RunDimensionNamePlaceholder:"Enter run dimension (Ex: Color)",RunConditions_ValueDescription:"The expected value for the run dimension.",RunConditions_ValuePlaceholder:"Enter value (Ex: Blue)",RunConditions_DataAvailabilityConditionNamePlaceholder:"Enter condition name (Ex: datasource01)",RunConditions_DataSourcesToMonitor:"Data source(s) to monitor",RunConditions_DataSourcesToMonitorDescription:"Select the data sources that must have new data available before this pipeline runs.",RunConditions_SelectDataSources:"Select data sources",RunConditions_AdvancedPlaceholder:"Advanced settings will be configured here.",RunConditions_TimeBasedConditionNamePlaceholder:"Enter condition name (Ex: schedule01)",RunConditions_PipelineSchedule:"Pipeline schedule",RunConditions_PipelineScheduleDescription:"Add a schedule to set when this pipeline runs.",RunConditions_AddSchedule:"Add schedule",RunConditions_EditSchedule:"Edit schedule",RunConditions_OpensPlatformScheduler:"Opens platform scheduler",RunConditions_UpstreamPipelines:"Upstream pipelines",RunConditions_UpstreamPipelinesCustomSubtitle:"Select upstream pipelines that have this run dimension and value. This controls when your downstream pipeline runs.",RunConditions_UpstreamPipelinesTimeBasedSubtitle:"Select upstream pipelines that have this schedule. This controls when your downstream pipeline runs.",RunConditions_SelectPipeline:"Select pipeline",RunConditions_RunDimension:"Run dimension",RunConditions_ScheduleType:"Schedule Type",RunConditions_OffsetDescription:"Time offset for the upstream pipeline schedule.",RunConditions_WindowSizeDescription:"Duration of the time window for the upstream pipeline schedule.",RunConditions_AddPipeline:"Add pipeline",RunConditions_TabDescription:"View and manage conditions that control when this pipeline runs.",RunConditions_ConditionStatus:"Condition status",RunConditions_ConditionTurnedOn:"Condition turned on",RunConditions_ConditionPaused:"Condition paused",RunConditions_CustomBasedCondition:"Custom-based condition",RunConditions_DataBasedCondition:"Data-based condition",RunConditions_NoMatchingConditions:"No matching conditions found.",RunConditions_EditRunCondition:"Edit run condition",RunConditions_EditDescription:"Edit the settings for this run condition."};globalThis.stringResources=stringResources;